# Copy this file to ".env" in the frontend/ directory.
# Base URL of the backend API (no trailing slash). Never hardcode this in code.
#
# IMPORTANT: Vite bakes VITE_* variables into the JS bundle at BUILD time,
# not at container runtime. If you deploy via the Dockerfile in this repo,
# your hosting platform must pass this as a Docker BUILD ARG named
# VITE_API_URL (not just a runtime environment variable), or the deployed
# site will keep calling the old URL no matter what env vars you set later.
#
# Production value for this project:
VITE_API_URL=https://qrcode.brillianttour.uz

# Password required to unlock the dashboard UI. This is a frontend-only
# gate — it's compared in the browser, not checked by the backend, so it
# only keeps out casual visitors, not a determined attacker (anyone can
# read it out of the built JS bundle). Same build-time-only caveat as
# VITE_API_URL applies here.
VITE_DASHBOARD_PASSWORD=change-me
